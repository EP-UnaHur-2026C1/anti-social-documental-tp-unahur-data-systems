        }
      }
    },
    {
      "name": "Usuarios - Seguir",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/usuarios/seguir",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "usuarios",
