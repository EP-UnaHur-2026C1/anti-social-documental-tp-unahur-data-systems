          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"seguidorId\": \"{{usuarioId}}\",\n  \"seguidoId\": \"{{otroUsuarioId}}\"\n}"
        }
      }
    },
    {
      "name": "Usuarios - Feed",
      "request": {
        "method": "GET",
        "url": {
