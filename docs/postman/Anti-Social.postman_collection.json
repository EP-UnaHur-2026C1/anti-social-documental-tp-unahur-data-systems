{
  "info": {
    "name": "Anti-Social Net API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleccion base para probar endpoints principales del TP"
  },
  "item": [
    {
      "name": "Usuarios - Crear",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/usuarios",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "usuarios"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nickName\": \"goku\"\n}"
        }
      }
    },
    {
      "name": "Posts - Crear",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/posts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "posts"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"descripcion\": \"Mi primer post\",\n  \"usuarioId\": \"{{usuarioId}}\"\n}"
        }
      }
    },
    {
      "name": "Posts - Listar",
      "request": {
        "method": "GET",
