          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "posts",
            "{{postId}}",
            "etiquetas"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"tp\"\n}"
        }
      }
    },
    {
      "name": "Posts - Agregar comentario",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
